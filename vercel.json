{
  "functions": {
    "*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "routes": [
    {
      "src": "^/(.*)\\.php$",
      "dest": "/$1.php"
    },
    {
      "src": "^/style\\.css$",
      "dest": "/style.css",
      "headers": {
        "content-type": "text/css"
      }
    },
    {
      "src": "^/(.*)$",
      "dest": "/index.php"
    }
  ],
  "overrides": {
    "*.css": {
      "headers": {
        "Content-Type": "text/css"
      }
    }
  }
}